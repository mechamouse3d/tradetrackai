# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tradetrack_ai_db"

# Server
PORT=5001
NODE_ENV=development

# JWT (for securing API calls if needed)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Auth0 (for token verification from frontend)
AUTH0_DOMAIN="your-auth0-domain.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
